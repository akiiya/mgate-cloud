# /etc/mgate-cloud/mgate-cloud.env  （权限 600，仅 root/mgate 可读）
#
# 生产环境务必：MGATE_MODE=prod、设置固定 MGATE_APP_SECRET、MGATE_COOKIE_SECURE=true。

MGATE_MODE=prod
MGATE_HTTP_ADDR=127.0.0.1:8080
MGATE_DB_PATH=/var/lib/mgate-cloud/mgate-cloud.db
MGATE_BASE_URL=https://cloud.example.com
MGATE_COOKIE_SECURE=true

# 真实客户端 IP 自动解析（CF-Connecting-IP → X-Forwarded-For → RemoteAddr），无需配置。
# 前提：本服务只经反代访问、不直接裸奔公网（如上 127.0.0.1 监听 + 反代回源）。

# 设备码签名密钥：固定且足够随机，例如 openssl rand -base64 32。为空时生产模式拒绝启动。
MGATE_APP_SECRET=__CHANGE_ME__

# 首次启动创建管理员；创建成功后建议移除 MGATE_ADMIN_PASSWORD。
MGATE_ADMIN_USERNAME=admin
MGATE_ADMIN_PASSWORD=__CHANGE_ME__
